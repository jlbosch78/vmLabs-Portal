# =========================
# VM Labs Portal - .env.example
# =========================
# 
# Copia este fichero a .env y rellena valores reales.

# -------------------------
# vCenters (multi)
# -------------------------
# Puedes definir varios vCenters en JSON agregando o quitando lineas
# 
# IMPORTANTE: Sustituye host, user, y pass valores reales.

VCENTERS_JSON='{
  "prof": {"label":"Laboratorios","host":"vcenter.example.local","user":"administrator@vsphere.local","pass":"CHANGE_ME","verify_ssl":false},
  "dev":  {"label":"Desarrollo","host":"vcenter-dev.example.local","user":"administrator@vsphere.local","pass":"CHANGE_ME","verify_ssl":false},
  "prod": {"label":"Producción","host":"vcenter-prod.example.local","user":"administrator@vsphere.local","pass":"CHANGE_ME","verify_ssl":false}
}'

#Vcenter que veran por defecto los roles "Profesor"
DEFAULT_VCENTER=prof
PROF_VCENTER=prof

# -------------------------
# Portal (login local)
# -------------------------
# Se usa para crear el admin inicial si la base de datos está vacía.
AUTH_USER=admin
AUTH_PASS=CHANGE_ME
FLASK_SECRET=CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME
FLASK_PORT=5000

# -------------------------
# Runtime / storage
# -------------------------
TMP_DIR=/tmp/vclab_jobs
POLL_INTERVAL_MS=15000
USER_DB_PATH=/data/users.db

# -------------------------
# Timezone
# -------------------------
TZ=Europe/Madrid

# -------------------------
# Scheduler logs
# -------------------------
# 1 = verbose (tick + runs), 0 = solo RUN/ERROR
VMLABS_SCHED_VERBOSE=0
